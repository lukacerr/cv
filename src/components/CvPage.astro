---
import { Badge } from '@/components/starwind/badge';
import {
	Card,
	CardContent,
	CardDescription,
	CardHeader,
	CardTitle,
} from '@/components/starwind/card';
import { Separator } from '@/components/starwind/separator';
import { ThemeToggle } from '@/components/starwind/theme-toggle';
import type { CvData } from '@/i18n/cv';
import { type Locale, languages } from '@/i18n/ui';
import { useTranslatedPath } from '@/i18n/utils';

interface Props {
	data: CvData;
	lang: Locale;
}

const { data, lang } = Astro.props;

function renderBullet(text: string): string {
	return text.replace(
		/`([^`]+)`/g,
		'<code class="rounded bg-muted px-1 py-0.5 text-xs font-medium text-foreground">$1</code>',
	);
}
---

<div class="mx-auto max-w-5xl p-6 md:p-10 print:p-0">
	{/* Dark mode toggle + Language switcher */}
	<div class="mb-6 flex items-center justify-end gap-3 print:hidden">
		{/* Language switcher */}
		<nav aria-label="Language" class="flex items-center gap-1 text-sm">
			{Object.entries(languages).map(([code, label], i) => (
				<>
					{i > 0 && <span class="text-muted-foreground">|</span>}
			{code === lang ? (
					<span class="font-bold text-foreground" aria-current="page">{code.toUpperCase()}</span>
				) : (
					<a
						href={useTranslatedPath(code as Locale)('/')}
						class="text-muted-foreground transition-colors hover:text-foreground"
						hreflang={code}
					>
						{code.toUpperCase()}
					</a>
				)}
			</>
		))}
		</nav>

		{/* LLM-friendly version */}
		<a
			href="/llm.md"
			target="_blank"
			rel="noopener noreferrer"
			class="rounded-lg border border-border bg-card p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
			aria-label="LLM-friendly version"
			title="LLM-friendly version"
		>
			<svg class="size-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M18 4a3 3 0 0 1 3 3v8a3 3 0 0 1 -3 3h-5l-5 3v-3h-2a3 3 0 0 1 -3 -3v-8a3 3 0 0 1 3 -3h12" /><path d="M9.5 9h.01" /><path d="M14.5 9h.01" /><path d="M9.5 13a3.5 3.5 0 0 0 5 0" /></svg>
		</a>

		{/* PDF download */}
		<a
			href={`/cv-${lang}.pdf`}
			target="_blank"
			rel="noopener noreferrer"
			class="rounded-lg border border-border bg-card p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
			aria-label={data.pdfLabel}
			title={data.pdfLabel}
		>
			<svg class="size-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2" /><path d="M11 12.5a1.5 1.5 0 0 0 -3 0v3a1.5 1.5 0 0 0 3 0" /><path d="M13 11l1.5 6l1.5 -6" /></svg>
		</a>

		{/* Source code repo */}
		<a
			href="https://github.com/lukacerr/cv"
			target="_blank"
			rel="noopener noreferrer"
			class="rounded-lg border border-border bg-card p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
			aria-label={data.repoLabel}
			title={data.repoLabel}
		>
			<svg class="size-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>
		</a>

		{/* Dark mode toggle */}
		<ThemeToggle variant="outline" size="sm" ariaLabel={data.darkModeLabel} />
	</div>

	{/* Two-column layout */}
	<div class="grid grid-cols-1 gap-8 md:grid-cols-[1fr_2fr]">

		{/* ===== LEFT SIDEBAR ===== */}
		<aside class="space-y-6">
			{/* Header */}
			<header class="max-md:motion-safe:opacity-0 max-md:motion-safe:translate-y-3 intersect:max-md:motion-safe:opacity-100 intersect:max-md:motion-safe:translate-y-0 max-md:motion-safe:transition-all max-md:motion-safe:duration-500 max-md:motion-safe:ease-out intersect-once print:opacity-100 print:translate-y-0">
				<h1 class="font-heading text-3xl font-bold tracking-tight">LUKA CERRUTTI</h1>
				<p class="text-lg text-primary-accent font-medium">{data.jobTitle}</p>
			</header>

			<Separator />

			{/* About */}
		<section class="max-md:motion-safe:opacity-0 max-md:motion-safe:translate-y-3 intersect:max-md:motion-safe:opacity-100 intersect:max-md:motion-safe:translate-y-0 max-md:motion-safe:transition-all max-md:motion-safe:duration-500 max-md:motion-safe:ease-out max-md:motion-safe:delay-75 intersect-once print:opacity-100 print:translate-y-0">
			<h2 class="mb-2 font-heading text-sm font-semibold uppercase tracking-wider text-muted-foreground">{data.sections.about}</h2>
				<p class="text-sm leading-relaxed">
					{data.about}
				</p>
			</section>

			<Separator />

			{/* Contact */}
		<section class="max-md:motion-safe:opacity-0 max-md:motion-safe:translate-y-3 intersect:max-md:motion-safe:opacity-100 intersect:max-md:motion-safe:translate-y-0 max-md:motion-safe:transition-all max-md:motion-safe:duration-500 max-md:motion-safe:ease-out max-md:motion-safe:delay-100 intersect-once print:opacity-100 print:translate-y-0">
			<h2 class="mb-3 font-heading text-sm font-semibold uppercase tracking-wider text-muted-foreground">{data.sections.contact}</h2>
				<ul class="space-y-2 text-sm">
					<li class="flex items-center gap-2">
						<svg class="size-4 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" /><path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0" /></svg>
						Buenos Aires (CABA), Argentina
					</li>
					<li class="flex items-center gap-2">
						<svg class="size-4 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" /><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" /></svg>
						<a href="https://wa.me/5491134411061" target="_blank" rel="noopener noreferrer" class="hover:text-primary-accent transition-colors">+54 9 11 3441-1061</a>
					</li>
					<li class="flex items-center gap-2">
						<svg class="size-4 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10" /><path d="M3 7l9 6l9 -6" /></svg>
						<a href="mailto:lukacerrutti2002@gmail.com" class="hover:text-primary-accent transition-colors">lukacerrutti2002@gmail.com</a>
					</li>
					<li class="flex items-center gap-2">
						<svg class="size-4 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 11v5" /><path d="M8 8v.01" /><path d="M12 16v-5" /><path d="M16 16v-3a2 2 0 1 0 -4 0" /><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10" /></svg>
						<a href="https://linkedin.com/in/lce" target="_blank" rel="noopener noreferrer" class="hover:text-primary-accent transition-colors">linkedin.com/in/lce</a>
					</li>
					<li class="flex items-center gap-2">
						<svg class="size-4 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>
						<a href="https://github.com/lukacerr" target="_blank" rel="noopener noreferrer" class="hover:text-primary-accent transition-colors">github.com/lukacerr</a>
					</li>
				</ul>
				<a
					href="https://calendar.app.google/RH6LJ5hLQPE92U9D9"
					target="_blank"
					rel="noopener noreferrer"
					class="mt-3 flex w-full items-center justify-center gap-2 rounded-lg border border-primary bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-primary/10 print:hidden"
				>
					<svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.5 21h-4.5a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v3" /><path d="M16 3v4" /><path d="M8 3v4" /><path d="M4 11h10" /><path d="M14 18a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" /><path d="M18 16.5v1.5l.5 .5" /></svg>
					{data.meetLabel}
				</a>
			</section>

			<Separator />

		{/* Languages */}
		<section class="max-md:motion-safe:opacity-0 max-md:motion-safe:translate-y-3 intersect:max-md:motion-safe:opacity-100 intersect:max-md:motion-safe:translate-y-0 max-md:motion-safe:transition-all max-md:motion-safe:duration-500 max-md:motion-safe:ease-out max-md:motion-safe:delay-150 intersect-once print:opacity-100 print:translate-y-0">
			<h2 class="mb-3 font-heading text-sm font-semibold uppercase tracking-wider text-muted-foreground">{data.sections.languages}</h2>
			<div class="space-y-3">
		{data.languages.map((l) => (
				<div>
					<div class="mb-1 flex items-center justify-between text-sm">
						<span class="flex items-center gap-1.5">
							<span>{l.flag}</span>
							<span>{l.name}</span>
						</span>
						<Badge variant="outline" size="sm">{l.level}</Badge>
					</div>
					<div class="h-1.5 w-full rounded-full bg-muted">
						<div class="h-1.5 rounded-full bg-primary transition-all" style={`width: ${l.proficiency}%`} />
					</div>
				</div>
			))}
			</div>
		</section>

		<Separator />

		{/* Education */}
		<section class="max-md:motion-safe:opacity-0 max-md:motion-safe:translate-y-3 intersect:max-md:motion-safe:opacity-100 intersect:max-md:motion-safe:translate-y-0 max-md:motion-safe:transition-all max-md:motion-safe:duration-500 max-md:motion-safe:ease-out max-md:motion-safe:delay-200 intersect-once print:opacity-100 print:translate-y-0">
			<h2 class="mb-3 font-heading text-sm font-semibold uppercase tracking-wider text-muted-foreground">{data.sections.education}</h2>
			<div class="space-y-3">
				{data.education.map((edu) => (
					<div class="flex items-start gap-2.5">
						<div class="flex size-8 shrink-0 items-center justify-center rounded-md bg-muted">
							{edu.logo ? (
								<img src={edu.logo} alt={edu.institution} class="size-6 rounded object-contain" />
							) : (
								<svg class="size-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M22 9l-10 -4l-10 4l10 4l10 -4v6" /><path d="M6 10.6v5.4a6 3 0 0 0 12 0v-5.4" /></svg>
							)}
						</div>
					<div class="min-w-0 flex-1">
						<div class="flex items-baseline justify-between gap-2">
							<span class="truncate text-sm font-medium" title={edu.institution}>{edu.institution}</span>
							<span class="shrink-0 text-xs text-muted-foreground">{edu.period}</span>
						</div>
							<p class="text-xs text-muted-foreground">{edu.description}</p>
						</div>
					</div>
				))}
			</div>
		</section>

		<Separator />

		{/* Soft Skills */}
			<section class="max-md:motion-safe:opacity-0 max-md:motion-safe:translate-y-3 intersect:max-md:motion-safe:opacity-100 intersect:max-md:motion-safe:translate-y-0 max-md:motion-safe:transition-all max-md:motion-safe:duration-500 max-md:motion-safe:ease-out max-md:motion-safe:delay-[250ms] intersect-once print:opacity-100 print:translate-y-0">
				<h2 class="mb-3 font-heading text-sm font-semibold uppercase tracking-wider text-muted-foreground">{data.sections.softSkills}</h2>
				<ul class="space-y-1.5 text-sm">
					{data.softSkills.map((skill) => (
						<li class="flex items-center justify-between">
							<span class="flex items-center gap-2">
								<span class="size-1.5 shrink-0 rounded-full bg-primary" />
								<span class="font-medium">{skill.label}</span>
							</span>
							<span class="text-muted-foreground">{skill.description}</span>
						</li>
					))}
				</ul>
				<p class="mt-3 text-xs text-muted-foreground leading-relaxed">
					{data.softSkillsSummary}
				</p>
			</section>
		</aside>

		{/* ===== RIGHT MAIN CONTENT ===== */}
		<main class="space-y-8">
			{/* Projects */}
			<section class="max-md:motion-safe:opacity-0 max-md:motion-safe:translate-y-3 intersect:max-md:motion-safe:opacity-100 intersect:max-md:motion-safe:translate-y-0 max-md:motion-safe:transition-all max-md:motion-safe:duration-500 max-md:motion-safe:ease-out intersect-once print:opacity-100 print:translate-y-0">
				<div class="mb-4 flex items-center gap-2">
					<svg class="size-5 text-primary-accent" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3 -5a9 9 0 0 0 6 -8a3 3 0 0 0 -3 -3a9 9 0 0 0 -8 6a6 6 0 0 0 -5 3" /><path d="M7 14a6 6 0 0 0 -3 6a6 6 0 0 0 6 -3" /><path d="M14 9a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /></svg>
					<h2 class="font-heading text-xl font-semibold">{data.sections.projects}</h2>
				</div>
				<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
					{data.projects.map((project) => (
						<a
							href={project.url}
							target="_blank"
							rel="noopener noreferrer"
							class="group relative flex flex-col items-center gap-3 rounded-xl bg-muted/70 dark:bg-muted/50 p-5 ring-1 ring-border transition-colors hover:ring-primary/50"
						>
							<svg class="absolute top-3 right-3 size-3.5 text-muted-foreground opacity-50 group-hover:opacity-100 transition-opacity" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6" /><path d="M11 13l9 -9" /><path d="M15 4h5v5" /></svg>
							{project.logo ? (
								<img src={project.logo} alt={project.name} class="size-10 rounded-lg object-contain" />
							) : (
								<div class="flex size-10 items-center justify-center rounded-lg bg-background">
									<svg class="size-5 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3 -5a9 9 0 0 0 6 -8a3 3 0 0 0 -3 -3a9 9 0 0 0 -8 6a6 6 0 0 0 -5 3" /><path d="M7 14a6 6 0 0 0 -3 6a6 6 0 0 0 6 -3" /><path d="M14 9a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /></svg>
								</div>
							)}
							<span class="text-sm font-medium">{project.name}</span>
							<span class="text-center text-xs text-muted-foreground">{project.description}</span>
						</a>
					))}
				</div>
			</section>

			<Separator />

			{/* Experience */}
			<section class="max-md:motion-safe:opacity-0 max-md:motion-safe:translate-y-3 intersect:max-md:motion-safe:opacity-100 intersect:max-md:motion-safe:translate-y-0 max-md:motion-safe:transition-all max-md:motion-safe:duration-500 max-md:motion-safe:ease-out max-md:motion-safe:delay-75 intersect-once print:opacity-100 print:translate-y-0">
				<div class="mb-4 flex items-center gap-2">
					<svg class="size-5 text-primary-accent" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 9a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2l0 -9" /><path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2" /><path d="M12 12l0 .01" /><path d="M3 13a20 20 0 0 0 18 0" /></svg>
					<h2 class="font-heading text-xl font-semibold">{data.sections.experience}</h2>
				</div>
			<div class="space-y-4">
				{data.experience.map((job) => (
					<Card size="sm" class={job.current ? 'ring-primary/50' : ''}>
						<CardHeader>
							<div class="flex items-start gap-3">
								<div class="flex size-8 shrink-0 items-center justify-center rounded-md bg-muted">
									{job.logo ? (
										<img src={job.logo} alt={job.company} class="size-6 rounded object-contain" />
									) : (
										<svg class="size-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 21l18 0" /><path d="M9 8l1 0" /><path d="M9 12l1 0" /><path d="M9 16l1 0" /><path d="M14 8l1 0" /><path d="M14 12l1 0" /><path d="M14 16l1 0" /><path d="M5 21v-16a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v16" /></svg>
									)}
								</div>
								<div class="min-w-0 flex-1">
									<div class="flex items-baseline justify-between gap-2">
										<CardTitle>
										{job.url ? (
											<a href={job.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-baseline gap-1 transition-colors hover:text-primary-accent">{job.company}<svg class="size-3 shrink-0 self-center" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6" /><path d="M11 13l9 -9" /><path d="M15 4h5v5" /></svg></a>
										) : (
											job.company
										)}
									</CardTitle>
										<span class="flex shrink-0 items-center gap-1.5 text-xs text-muted-foreground">
											{job.current && <span class="size-2 rounded-full bg-primary animate-pulse" />}
											{job.period}
										</span>
									</div>
									<CardDescription>{job.role}</CardDescription>
								</div>
							</div>
						</CardHeader>
						<CardContent>
